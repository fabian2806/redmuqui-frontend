# =====================================================================
# Variables de entorno para el frontend Next.js
# Copiar este archivo como .env.local y ajustar valores según necesidad.
# .env.local NO se versiona (está en .gitignore).
# =====================================================================

# URL base del backend Spring Boot (sin slash final).
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_OCR_API_URL=http://alb-ocr-409799641.us-east-1.elb.amazonaws.com
# Modo de autenticación:
#   - "real" (recomendado): login y /usuarios/me reales contra el backend.
#   - "mock": useAuth devuelve admin hardcodeado solo para prototipos.
NEXT_PUBLIC_AUTH_MODE=real
